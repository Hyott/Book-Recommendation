    "import json\n",
    "\n",
    "# 파일 로드 함수\n",
    "def load_json(file_path):\n",
    "    with open(file_path, 'r', encoding='utf-8') as f:\n",
    "        return json.load(f)\n",
    "\n",
    "# 파일 저장 함수\n",
    "def save_json(file_path, data):\n",
    "    with open(file_path, 'w', encoding='utf-8') as f:\n",
    "        json.dump(data, f, ensure_ascii=False, indent=4)\n",
    "\n",
    "# 병합 함수\n",
    "def merge_json(file1, file2, output_file):\n",
    "    data1 = load_json(file1)\n",
    "    data2 = load_json(file2)\n",
    "\n",
    "    # JSON 병합 (기본적으로 dictionary merge)\n",
    "    merged_data = {}  # 중복 키가 있으면 file2 데이터가 우선됨\n",
    "\n",
    "    # 첫 번째 파일의 데이터 추가\n",
    "    for i, (key, value) in enumerate(data1.items(), start=1):\n",
    "        merged_data[f\"book{i}\"] = value\n",
    "\n",
    "    # 두 번째 파일의 데이터 추가 (book1001부터 시작)\n",
    "    start_index = len(data1) + 1  # book1001부터 시작\n",
    "    for i, (key, value) in enumerate(data2.items(), start=start_index):\n",
    "        merged_data[f\"book{i}\"] = value\n",
    "\n",
    "    # 결과 저장\n",
    "    save_json(output_file, merged_data)\n",
    "\n",
    "# 사용 예시\n",
    "merge_json(\"notebook/data/llm_output[0~1000].json\", \"notebook/data/llm_output.json\", \"notebook/data/llm_final_output.json\")\n",
    "\n",
    "print(\"JSON 병합 완료: llm_final_output.json\")"
   ]
